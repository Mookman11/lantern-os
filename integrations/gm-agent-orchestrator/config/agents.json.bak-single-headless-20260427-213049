{
    "fallbackWaitMinutes":  300,
    "maxResumeCycles":  4,
    "slots":  [
                  {
                      "name":  "codex-main",
                      "agent":  "codex",
                      "role":  "implementation",
                      "enabled":  true,
                      "branch":  "agent/codex-main",
                      "command":  {
                                      "start":  [
                                                    "codex",
                                                    "exec",
                                                    "{prompt}"
                                                ],
                                      "resume":  [
                                                     "codex",
                                                     "exec",
                                                     "resume",
                                                     "--last",
                                                     "{prompt}"
                                                 ]
                                  }
                  },
                  {
                      "name":  "claude-main",
                      "agent":  "claude",
                      "role":  "implementation-review",
                      "enabled":  true,
                      "branch":  "agent/claude-main",
                      "command":  {
                                      "start":  [
                                                    "claude",
                                                    "--dangerously-skip-permissions",
                                                    "--print",
                                                    "{prompt}"
                                                ],
                                      "resume":  [
                                                     "claude",
                                                     "--dangerously-skip-permissions",
                                                     "--continue",
                                                     "--print",
                                                     "{prompt}"
                                                 ],
                                      "fallbackResume":  [
                                                             "claude",
                                                             "--dangerously-skip-permissions",
                                                             "-p",
                                                             "--continue",
                                                             "{prompt}"
                                                         ]
                                  }
                  },
                  {
                      "name":  "gemini-main",
