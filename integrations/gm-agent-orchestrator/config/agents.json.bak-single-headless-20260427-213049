                                                    "-p",
                                                    "{prompt}",
                                                    "--skip-trust"
                                                ],
                                      "resume":  [
                                                     "gemini",
                                                     "-p",
                                                     "{prompt}",
                                                     "--skip-trust"
                                                 ]
                                  }
                  },
