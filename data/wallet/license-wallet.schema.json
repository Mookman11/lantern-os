{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alex-place/lantern-os/blob/master/data/wallet/license-wallet.schema.json",
  "title": "Lantern OS License Wallet",
  "description": "Internal entitlement ledger for one Lantern OS licensed user. Not stored value, not a bank account, not crypto custody, not transferable cash.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "licenseWalletId",
    "userId",
    "licenseId",
    "walletType",
    "paymentProvider",
    "acceptedMethods",
    "currency",
    "clearedCashUsd",
    "transferable",
    "withdrawable",
    "redeemableForCash",
    "events"
  ],
  "properties": {
    "licenseWalletId": {
      "type": "string",
      "pattern": "^lw_[a-zA-Z0-9_-]+$"
    },
    "userId": {
      "type": "string",
      "description": "Internal user key. Do not store raw PIID here."
    },
    "licenseId": {
      "type": "string"
    },
    "walletType": {
      "const": "internal_entitlement_ledger_not_stored_value"
    },
    "paymentProvider": {
      "type": "string",
      "enum": ["stripe", "paypal", "manual_invoice", "none"]
    },
    "acceptedMethods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["apple_pay", "card", "paypal", "manual_invoice"]
      },
      "uniqueItems": true
    },
    "currency": {
      "const": "USD"
    },
    "clearedCashUsd": {
      "type": "number",
      "minimum": 0
    },
    "pendingUsd": {
      "type": "number",
      "minimum": 0,
      "default": 0
    },
    "transferable": {
      "const": false
    },
    "withdrawable": {
      "const": false
    },
    "redeemableForCash": {
      "const": false
    },
    "accessEntitlements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eventId", "timestamp", "type", "amountUsd", "evidenceClass", "note"],
        "properties": {
          "eventId": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"},
          "type": {
            "type": "string",
            "enum": ["license_created", "invoice_drafted", "invoice_sent", "payment_pending", "payment_cleared", "refund_recorded", "entitlement_granted", "entitlement_revoked", "manual_note"]
          },
          "amountUsd": {"type": "number", "minimum": 0},
          "providerReference": {"type": "string"},
          "evidenceClass": {
            "type": "string",
            "enum": ["local_verified", "github_metadata", "source_repo_evidence", "official_source", "operator_asserted", "operator_private_context", "web_secondary", "projection", "unknown"]
          },
          "note": {"type": "string"}
        }
      },
      "default": []
    }
  }
}
