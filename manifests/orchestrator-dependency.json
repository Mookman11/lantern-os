{
  "schema": "lantern.orchestrator_dependency.v1",
  "dependencyId": "gm-agent-orchestrator-local",
  "label": "GM Agent Orchestrator as Lantern OS dependency",
  "repoPath": "C:\\Users\\alexp\\Documents\\gm-agent-orchestrator",
  "mcp": {
    "healthUrl": "http://127.0.0.1:8787/health",
    "rpcUrl": "http://127.0.0.1:8787/mcp",
    "transport": "http_jsonrpc",
    "localOnly": true
  },
  "requiredReadTools": [
    "get_agent_status",
    "get_queue_summary",
    "get_recent_failures",
    "get_latest_agent_logs",
    "get_mcp_capability_status",
    "get_mcp_feature_overview"
  ],
  "requiredMutationToolsHeldBehindApproval": [
    "start_agent",
    "rerun_agent",
    "create_queue_task",
    "requeue_task",
    "fail_task",
    "complete_task"
  ],
  "slotFreshnessPolicy": {
    "maxStatusAgeMinutes": 30,
    "activeSlotRequiresActiveTask": true,
    "activeSlotRequiresLiveRunnerEvidence": true,
    "staleSlotsAreNotAvailable": true,
    "dirtyWorktreesBlockDispatch": true
  },
  "targetLanternSlots": [
    {
      "slot": "lantern-operator-approval",
      "agent": "human-interface",
      "purpose": "Human approval and investor/auth gate."
    },
    {
      "slot": "lantern-codex-impl",
      "agent": "codex",
      "purpose": "Small implementation tasks after dependency and worktree preflight."
    },
    {
      "slot": "lantern-gemini-research",
      "agent": "gemini",
      "purpose": "Low-cost research and source compression after auth/quota preflight."
    },
    {
      "slot": "lantern-gpt-web-preview",
      "agent": "gpt-web",
      "purpose": "Browser preview validation after clean browser worktree and explicit task."
    }
  ],
  "lanternPolicy": {
    "dependencyMode": "external_local_dependency",
    "doNotTrustStaleStatusFiles": true,
    "doNotStartAgentsFromDashboardWithoutHumanApproval": true,
    "doNotCreateSlotsInsideDirtyOrchestratorRepo": true,
    "nextSafePath": "Validate dependency, preserve dirty orchestrator state, then create a clean orchestrator migration PR for lantern-* slots."
  }
}
