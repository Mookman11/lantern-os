{
  "schema_version": "theorem-register.v0.1",
  "status": "docs-data-anchor",
  "last_reviewed": "2026-05-09",
  "purpose": "Machine-readable theorem register for three-way convergence among Alex, Keystone/assistant, and the HFF repo theorem corpus.",
  "non_goals": [
    "runtime_code",
    "deployment_change",
    "secret_access",
    "medical_procedure",
    "mission_booking",
    "human_traversal",
    "copy_transfer_claim",
    "immortality_claim",
    "ai_impersonation_of_alex"
  ],
  "required_fields": [
    "theorem_id",
    "claim",
    "confidence",
    "source_class",
    "negative_tests",
    "pass_criteria",
    "fail_criteria",
    "last_reviewed",
    "next_safe_test"
  ],
  "confidence_scale": {
    "0.00": "blocked or unsupported",
    "0.25": "weak hypothesis",
    "0.50": "plausible but under-tested",
    "0.75": "strong working hypothesis",
    "0.90": "high-confidence operating rule",
    "1.00": "reserved; avoid for live doctrine"
  },
  "source_class_scale": {
    "0": "operational record with independent verification and relevant return evidence",
    "1": "official standards, regulators, agencies, primary scientific or peer-reviewed sources",
    "2": "high-quality secondary summary of primary evidence",
    "3": "vendor roadmap, company milestone, or product/platform documentation",
    "4": "press, popular science, explanatory media, or weak secondary context",
    "5": "fictional world, fan theory, tabloid, influencer, self-claim, or cultural signal only",
    "6": "uncited, anonymous, emotionally attractive, or unsupported assertion"
  },
  "source_class_promotion_rule": "A lower source class may inspire a hypothesis but must not be promoted to operational proof without a testable evidence update.",
  "theorems": [
    {
      "theorem_id": "T1",
      "title": "Return-first door theorem",
      "claim": "A door is not human-preserving if safe return, rescue, abort, and reintegration are weaker than crossing.",
      "confidence": 0.93,
      "source_class": [1, "repo_anchor", "working_hypothesis"],
      "source_urls": [
        "https://sma.nasa.gov/sma-disciplines/planetary-protection",
        "https://www.nasa.gov/hrp/hazards/",
        "https://www.faa.gov/space/human_spaceflight"
      ],
      "negative_tests": [
        "no_return_path",
        "no_abort_path",
        "no_rescue_path",
        "no_hold_or_reintegration_plan",
        "human_crossing_claim_without_canary_evidence"
      ],
      "pass_criteria": [
        "signal_or_canary_crossing_is_observed",
        "same_canary_or_traveler_can_return",
        "return_is_recoverable_and_verifiable",
        "abort_and_rescue_paths_are_defined",
        "independent_challenge_can_pause_the_claim"
      ],
      "fail_criteria": [
        "one_way_only",
        "return_is_assumed_not_demonstrated",
        "rescue_or_abort_is_missing",
        "claim_depends_on_metaphor_or_vendor_confidence"
      ],
      "human_risk_note": "Blocks romantic or heroic crossing claims when return is not stronger than launch/crossing.",
      "last_reviewed": "2026-05-09",
      "next_safe_test": "Add a unit-style data test that rejects any door record where human_traversal=true and min(crossing_confidence, safe_return_confidence, person_continuity_confidence) is below threshold.",
      "repo_anchors": [
        "HUMAN_TRANSPORTATION_BOUNDARY.md",
        "docs/full-door-convergence-2026-05-09.md"
      ]
    },
