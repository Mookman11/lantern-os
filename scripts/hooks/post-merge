#!/bin/sh
# post-merge: stale-branch audit + changelog-fragment reminder (master/dev only)
# Runs automatically after every `git merge` or `git pull`.

current=$(git symbolic-ref --short HEAD 2>/dev/null)
case "$current" in master|dev) ;; *) exit 0 ;; esac

# ── 1. Stale branch audit ────────────────────────────────────────────────────
stale=""
while IFS= read -r _b; do
  _b=$(echo "$_b" | sed 's/^\* //' | xargs)
  case "$_b" in master|dev|gh-pages|HEAD|"") continue ;; esac
  _behind=$(git rev-list --count "$_b"..HEAD 2>/dev/null || echo 0)
  if [ "$_behind" -gt 10 ]; then
    stale="${stale}  ${_b}  (${_behind} behind)\n"
  fi
done < <(git branch)

if [ -n "$stale" ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "STALE BRANCHES — sync to avoid future conflicts"
  printf "%b" "$stale"
  echo ""
  echo "For each branch: git checkout <branch> && git rebase master"
  echo "Or delete stale: git branch -D <branch>"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
fi

# ── 2. Changelog fragment reminder (master only) ─────────────────────────────
if [ "$current" = "master" ]; then
  _root=$(git rev-parse --show-toplevel 2>/dev/null)
  _frag_dir="$_root/changelog.d"
  if [ -d "$_frag_dir" ]; then
    _frag_count=$(find "$_frag_dir" -maxdepth 1 -name "*.md" \
      ! -name "README.md" ! -name "_*" ! -name ".*" 2>/dev/null | wc -l | tr -d ' ')
    if [ "${_frag_count:-0}" -gt 0 ]; then
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "CHANGELOG FRAGMENTS PENDING ($_frag_count file(s) in changelog.d/)"
      echo ""
      echo "  Assemble + bump version:"
      echo "    node scripts/assemble-changelog.js          # patch (default)"
      echo "    node scripts/assemble-changelog.js minor    # minor"
      echo ""
      echo "  Then commit:"
      echo "    git add package.json apps/lantern-garage/package.json \\"
      echo "          apps/lantern-garage/version.json CHANGELOG.MD changelog.d/"
      echo "    git commit -m \"chore(release): bump to \$(node -p \\\"require('./package.json').version\\\")\""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
    fi
  fi
fi

exit 0
