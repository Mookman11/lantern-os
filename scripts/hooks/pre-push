#!/bin/sh
# Monoworkstream gate + master protection + LFS check

# 1. Block direct pushes to master
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/master" ]; then
    printf >&2 "\n%s\n\n" "Direct push to master is blocked. Open a pull request instead."
    exit 1
  fi
done

# 2. Monoworkstream: refuse pushes of NEW branches while any PR is open.
#    Pushes to a branch that already has an open PR are always allowed.
#    Exempt branches: gh-pages (deploy-only) does not count as a workstream.
if [ "$SKIP_MONOWORKSTREAM" != "1" ]; then
  if command -v gh >/dev/null 2>&1; then
    # Extract branch name from the first ref being pushed
    branch=$(echo "$local_ref" | sed 's|refs/heads/||')
    if [ -n "$branch" ]; then
      # Exempt branches: long-lived deploy branches don't count as workstreams
      if [ "$branch" = "gh-pages" ]; then
        :
      else
        # Check if this branch already has an open PR
        branch_has_pr=$(gh pr list --repo alex-place/lantern-os --state open --json headRefName --jq "map(select(.headRefName == \"\$branch\")) | length" 2>/dev/null)
        if [ $? -eq 0 ] && [ "$branch_has_pr" -gt 0 ]; then
          # This branch already has an open PR — allow the push (you're updating the PR)
          :
        else
          # No PR from this branch; check if ANY other PR is open
          open_count=$(gh pr list --repo alex-place/lantern-os --state open --json number --jq 'length' 2>/dev/null)
          if [ $? -eq 0 ] && [ "$open_count" -gt 0 ]; then
            printf >&2 "\n%s\n" "MONOWORKSTREAM BLOCK: $open_count PR(s) still open."
            gh pr list --repo alex-place/lantern-os --state open --json number,title,headRefName --jq '.[] | "  #\(.number) \(.title) [\(.headRefName)]"' 2>/dev/null >&2
            printf >&2 "\n%s\n\n" "Finish or close the open PR before pushing a new branch. You can still push to a branch that already has an open PR. Bypass: SKIP_MONOWORKSTREAM=1 git push ..."
            exit 1
          fi
        fi
      fi
    fi
  fi
fi

# 3. Git LFS
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"
