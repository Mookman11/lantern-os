#!/bin/sh
# prepare-commit-msg: inject conventional commits template for fresh commits.
#
# Only fires on a blank `git commit` (not --amend, not merge, squash, fixup).
# Bypass: set SKIP_MONOWORKSTREAM=1 or just type your own message over the template.

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Only inject when there is no source (fresh interactive commit)
[ -n "$COMMIT_SOURCE" ] && exit 0

# If the file already has a non-comment line, don't override
grep -qv '^#' "$COMMIT_MSG_FILE" 2>/dev/null && exit 0

cat > "$COMMIT_MSG_FILE" << 'TEMPLATE'
# type(scope): short description — imperative mood, ≤72 chars
#
# Types : feat · fix · chore · docs · test · refactor · perf · ci · revert
# Scopes: dream-chat · trading · csf · mcp · auth · ui · infra · release
#
# Body (optional — explain WHY, not what; reference issues with #NNN):
#
#
# Loop stage this commit strengthens (required for non-trivial changes):
#   Remember · Reason · Verify · Act · Converge
#
# Examples:
#   feat(dream-chat): add voice capture to entry field
#   fix(trading): correct Kalshi 429 backoff on burst
#   chore(release): bump to 1.7.50
TEMPLATE
