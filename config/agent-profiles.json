{
  "version": "2.0.0",
  "description": "Lantern OS Agent Profiles — First-class diverse agent fleet. Each profile maps to a real CLI tool with auth, capabilities, and fallback chains.",
  "profiles": [
    {
      "id": "claude-primary",
      "agent": "claude",
      "provider": "anthropic",
      "model": "claude-opus",
      "taskBudget": "high",
      "requiredEnvVars": ["ANTHROPIC_API_KEY"],
      "capabilities": ["architecture_decisions", "complex_analysis", "documentation", "code_review", "strategic_planning", "safety-review", "git", "validation"],
      "fallbackChain": ["codex-primary", "gemini-primary", "devin-primary"],
      "cliCommand": ["claude", "--dangerously-skip-permissions"],
      "maxTokens": 200000,
      "parallelTasks": 3
    },
    {
      "id": "codex-primary",
      "agent": "codex",
      "provider": "openai",
      "model": "gpt-4-turbo",
      "taskBudget": "high",
      "requiredEnvVars": ["OPENAI_API_KEY"],
      "capabilities": ["feature_implementation", "bug_fixes", "code_generation", "test_writing", "refactoring", "git", "validation"],
      "fallbackChain": ["gemini-primary", "devin-primary", "claude-primary"],
      "cliCommand": ["codex"],
      "maxTokens": 128000,
      "parallelTasks": 2
    },
    {
      "id": "gemini-primary",
      "agent": "gemini",
      "provider": "google",
      "model": "gemini-pro",
      "taskBudget": "medium",
      "requiredEnvVars": ["GOOGLE_API_KEY"],
      "capabilities": ["content_analysis", "documentation_generation", "problem_decomposition", "validation", "research", "git"],
      "fallbackChain": ["devin-primary", "claude-primary", "codex-primary"],
      "cliCommand": ["gemini"],
      "maxTokens": 100000,
      "parallelTasks": 2
    },
    {
      "id": "devin-primary",
      "agent": "devin",
      "provider": "cognition",
      "model": "devin",
      "taskBudget": "high",
      "requiredEnvVars": ["DEVIN_API_KEY"],
      "capabilities": ["deep_engineering_work", "complex_debugging", "performance_optimization", "system_design", "integration", "git", "validation"],
      "fallbackChain": ["claude-primary", "codex-primary", "gemini-primary"],
      "cliCommand": ["devin"],
      "maxTokens": 150000,
      "parallelTasks": 2
    },
    {
      "id": "ollama-primary",
      "agent": "ollama",
      "provider": "ollama",
      "model": "llama3.2",
      "taskBudget": "low",
      "requiredEnvVars": ["OLLAMA_BASE_URL"],
      "capabilities": ["dream_journal", "local_rp", "privacy_first", "offline_friendly", "validation"],
      "fallbackChain": ["groq-primary", "deepseek-primary", "openai-primary"],
      "cliCommand": ["ollama", "run", "{model}"],
      "maxTokens": 4096,
      "parallelTasks": 1
    },
    {
      "id": "deepseek-primary",
      "agent": "deepseek",
      "provider": "deepseek",
      "model": "deepseek-chat",
      "taskBudget": "medium",
      "requiredEnvVars": ["DEEPSEEK_API_KEY"],
      "capabilities": ["dream_journal", "code_generation", "analysis", "validation"],
      "fallbackChain": ["groq-primary", "openai-primary", "gemini-primary"],
      "cliCommand": ["curl", "-H", "Authorization: Bearer {DEEPSEEK_API_KEY}", "https://api.deepseek.com/chat/completions"],
      "maxTokens": 8192,
      "parallelTasks": 2
    },
    {
      "id": "groq-primary",
      "agent": "groq",
      "provider": "groq",
      "model": "llama-3.1-70b-versatile",
      "taskBudget": "medium",
      "requiredEnvVars": ["GROQ_API_KEY"],
      "capabilities": ["dream_journal", "fast_inference", "rp", "validation"],
      "fallbackChain": ["openai-primary", "deepseek-primary", "gemini-primary"],
      "cliCommand": ["curl", "-H", "Authorization: Bearer {GROQ_API_KEY}", "https://api.groq.com/openai/v1/chat/completions"],
      "maxTokens": 8192,
      "parallelTasks": 2
    },
    {
      "id": "azure-primary",
      "agent": "azure",
      "provider": "azure",
      "model": "gpt-4o",
      "taskBudget": "high",
      "requiredEnvVars": ["AZURE_OPENAI_KEY", "AZURE_OPENAI_ENDPOINT"],
      "capabilities": ["architecture_decisions", "complex_analysis", "documentation", "code_review", "strategic_planning", "git", "validation"],
      "fallbackChain": ["claude-primary", "openai-primary", "gemini-primary"],
      "cliCommand": ["az", "openai"],
      "maxTokens": 128000,
      "parallelTasks": 2
    },
    {
      "id": "generic-primary",
      "agent": "generic",
      "provider": "generic",
      "model": "default",
      "taskBudget": "low",
      "requiredEnvVars": ["GENERIC_BASE_URL"],
      "capabilities": ["dream_journal", "generic_inference", "validation"],
      "fallbackChain": ["ollama-primary", "groq-primary", "openai-primary"],
      "cliCommand": ["curl", "{GENERIC_BASE_URL}/chat/completions"],
      "maxTokens": 4096,
      "parallelTasks": 1
    },
    {
      "id": "super-jarvis-default",
      "agent": "super-jarvis",
      "provider": "mcp",
      "taskBudget": "low",
      "requiredEnvVars": ["MCP_SERVER_URL"],
      "capabilities": ["convergence", "validation", "git", "safety-check"],
      "fallbackChain": ["claude-primary", "codex-primary", "gemini-primary"],
      "cliCommand": ["powershell", "-File", "scripts/orchestration/Invoke-OrchestratorAgentAction.ps1"],
      "maxTokens": 50000,
      "parallelTasks": 1
    },
    {
      "id": "super-jarvis-primary",
      "agent": "super-jarvis",
      "provider": "mcp",
      "taskBudget": "medium",
      "requiredEnvVars": ["MCP_SERVER_URL", "DISCORD_BOT_TOKEN"],
      "capabilities": ["convergence", "validation", "git", "dispatch", "safety-check", "evidence-recording"],
      "fallbackChain": ["super-jarvis-default", "claude-primary"],
      "cliCommand": ["powershell", "-File", "scripts/orchestration/Invoke-OrchestratorAgentAction.ps1"],
      "maxTokens": 50000,
      "parallelTasks": 1
    }
  ]
}
